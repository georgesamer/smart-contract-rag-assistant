# Rename this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...
# If you are the evaluator:
# Please paste your OpenAI API key below.
# And change the empty line in "server.py" line 44.
# If left as it is, the system will fallback to the local Ollama model (if installed).

# URL of the FastAPI server (change if running on a remote machine)
SERVER_URL=http://localhost:8000
